---
import { SITE, SOCIALS } from "@/consts";
---

<section id="Contact" class="container mx-auto my-28 p-10 space-y-12">
    <h2 class="heading text-5xl md:text-7xl">Get in Touch</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 items-center gap-8">
        <div class="space-y-6">
            <p class="text-xl md:text-3xl max-w-xl">
                Got an idea or want to discuss a problem? Please reach out and let me know.
            </p>

            <div class="text-xl space-y-2">
                {
                    SOCIALS.map((link) => (
                        <p>
                            <a
                                href={link.HREF}
                                target="_blank"
                                class="underline hover:text-secondary transition"
                            >
                                {link.NAME}
                            </a>
                        </p>
                    ))
                }
            </div>
        </div>

        <form id="contact-form" action="https://api.web3forms.com/submit" method="POST" class="space-y-6">
            <input type="hidden" name="access_key" value={SITE.CONTACT_FORM_KEY} />
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div class="relative">
                    <input
                        type="text"
                        id="name"
                        name="name"
                        class="peer border border-secondary border-solid p-4 text-xl w-full focus:outline-none rounded-3xl placeholder-transparent"
                        placeholder="Name"
                        required
                    />
                    <label
                        for="name"
                        class="absolute left-4 -top-2 text-sm px-2 text-secondary bg-background transition-all peer-placeholder-shown:top-4 peer-placeholder-shown:text-xl peer-placeholder-shown:bg-transparent peer-placeholder-shown:text-foreground/70 peer-focus:-top-2 peer-focus:text-sm peer-focus:text-secondary peer-focus:bg-background"
                    >
                        Name
                    </label>
                </div>

                <div class="relative">
                    <input
                        type="email"
                        id="email"
                        name="email"
                        class="peer border border-secondary border-solid p-4 text-xl w-full focus:outline-none rounded-3xl placeholder-transparent"
                        placeholder="Email"
                        required
                    />
                    <label
                        for="email"
                        class="absolute left-4 -top-2 text-sm px-2 text-secondary bg-background transition-all peer-placeholder-shown:top-4 peer-placeholder-shown:text-xl peer-placeholder-shown:bg-transparent peer-placeholder-shown:text-foreground/70 peer-focus:-top-2 peer-focus:text-sm peer-focus:text-secondary peer-focus:bg-background"
                    >
                        Email
                    </label>
                </div>
            </div>

            <div class="relative">
                <textarea
                    id="message"
                    name="message"
                    rows="6"
                    class="peer border border-secondary border-solid p-4 text-xl w-full focus:outline-none rounded-3xl placeholder-transparent resize-none"
                    placeholder="Message"
                    required></textarea>
                <label
                    for="message"
                    class="absolute left-4 -top-2 text-sm px-2 text-secondary bg-background transition-all peer-placeholder-shown:top-4 peer-placeholder-shown:text-xl peer-placeholder-shown:bg-transparent peer-placeholder-shown:text-foreground/70 peer-focus:-top-2 peer-focus:text-sm peer-focus:text-secondary peer-focus:bg-background"
                >
                    Message
                </label>
            </div>

            <div id="h-captcha-widget" class="h-captcha" data-captcha="true"></div>
            <script is:inline>
                (function() {
                    const theme = document.documentElement.classList.contains('dark') || 
                                window.matchMedia('(prefers-color-scheme: dark)').matches 
                                ? 'dark' : 'light';
                    document.getElementById('h-captcha-widget').setAttribute('data-theme', theme);
                })();
            </script>
            
            <button
                type="submit"
                class="flex items-center justify-center bg-primary rounded-2xl py-3 px-6 sm:py-4 sm:px-10 cursor-pointer hover:bg-background hover:outline hover:outline-1 hover:outline-solid hover:outline-secondary hover:text-foreground transition"
            >
                Send Message
            </button>
        </form>
    </div>
</section>

<script src="https://web3forms.com/client/script.js" async defer></script>
<script>
    const form = document.getElementById('contact-form');

    form?.addEventListener('submit', function(e) {

        const hCaptcha = form?.querySelector<HTMLTextAreaElement>('textarea[name=h-captcha-response]')?.value;

        if (!hCaptcha) {
            e.preventDefault();
            alert("Please fill out captcha field")
            return
        }
    });
</script>
